rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Toda leitura e escrita passa pelas rotas da API Next.js (Firebase Admin SDK),
    // que ignoram estas regras. Acesso direto pelo SDK do cliente é bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
